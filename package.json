    "firebase": "^12.10.0",
    "json-server": "^1.0.0-beta.12",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.563.0",
    "nodemailer": "^8.0.5",
    "prop-types": "^15.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "sqlite3": "^6.0.1",
